# Copy to .env. All values are OPTIONAL — the API works fully keyless.
# These are server-only secrets; they never reach the browser.

# Enables the Claude (claude-sonnet-4-6) scoring + formatting agents. Without it,
# the pipeline still runs with a deterministic fallback (no LLM, fully keyless).
ANTHROPIC_API_KEY=

# Raises GitHub's API rate limit (60/hr → 5000/hr). Recommended for production.
GITHUB_TOKEN=

# Optional — if set, NewsAPI (newsapi.org) is added as an article source.
NEWS_API_KEY=

# Comma-separated CORS allowlist. Defaults to the GitHub Pages origin +
# localhost. Example:
# ALLOWED_ORIGINS=https://owenhong0.github.io,http://localhost:5173
ALLOWED_ORIGINS=
