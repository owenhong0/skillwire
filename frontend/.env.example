# Base URL of the Skillwire Dispatch backend (FastAPI on Render).
#
# Local dev: leave UNSET to fall back to direct, keyless GitHub calls for repos.
# (The news rail will show a "needs backend" note, since articles require the API.)
# To test against a local backend:  VITE_API_BASE=http://localhost:8000
#
# Production: set this at BUILD time so Vite inlines it into the bundle, e.g.
# VITE_API_BASE=https://skillwire-dispatch.onrender.com
VITE_API_BASE=https://skillwire.onrender.com
